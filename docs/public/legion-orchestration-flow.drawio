        <mxCell id="step-1" value="&lt;b&gt;1. 席予約&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:12px;color:#CBD5E1'&gt;Devil's Advocate・Material Design・second-pass lanes を fan-out 前に確保&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=18;fillColor=#111827;gradientColor=#0B1220;gradientDirection=southEast;strokeColor=#14B8A6;strokeWidth=2;fontFamily=Noto Sans JP;fontSize=14;fontColor=#F8FAFC;align=left;verticalAlign=middle;spacingTop=10;spacingLeft=16;spacingRight=14;spacingBottom=6;" vertex="1" parent="1">
